object Shape {
    inheritance:

    func sides() -> integer {
        return 0
    }
}

object Square: Shape {
    func sides() -> integer {
        return 4
    }
}

ref square: Square = { }
const directResult: integer = square.sides()
print directResult

ref polymorphShape: Shape = square
const polymorphResult: integer = polymorphShape.sides()
print polymorphResult
