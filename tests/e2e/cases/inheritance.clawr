object Super {
  func pureMethod() -> integer {
    return self.dataField
  }

inheritance:
  func new() => {dataField: 47}

data:
  dataField: integer
}

object Subtype: Super {
  // Override method in super
  func pureMethod() -> integer {
    return 42
  }

mutating:
  func mutatingMethod() {}

data:
   childField: integer
}

func makeSubtype() -> Subtype => {
    super.new()
    childField: 47
}

const o = makeSubtype()

print o.pureMethod()
